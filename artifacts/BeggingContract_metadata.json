			"methods": {
				"allDonors(uint256)": {
					"notice": "获取所有捐赠者列表（解决mapping无法遍历的问题） 注：需在donate函数中同步维护此列表"
				},
				"donate()": {
					"notice": "捐赠函数：仅在指定时间段内可捐赠，记录金额并触发事件"
				},
				"getContractBalance()": {
					"notice": "辅助：查询合约当前总余额"
				},
				"getDonation(address)": {
					"notice": "查询单个地址捐赠金额"
				},
				"getTop3Donors()": {
					"notice": "捐赠排行榜：返回捐赠金额最多的前3个地址及对应金额 返回格式：[地址1, 地址2, 地址3], [金额1, 金额2, 金额3] 若捐赠者不足3个，空缺位置返回空地址+0"
				},
				"updateDonationPeriod(uint256,uint256)": {
					"notice": "辅助：更新捐赠时间段（仅所有者）"
				},
				"withdraw()": {
					"notice": "提取资金函数：仅所有者可提取合约所有资金"
				}
			},
